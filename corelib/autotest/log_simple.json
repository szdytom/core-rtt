{
	"version": 1,
	"name": "ecall log/log_str simple test",
	"runs": 1,
	"timeLimitMs": 2000,
	"maxTicks": 10,
	"program": [
		{
			"base": "log_simple",
			"unit": "@dummy"
		},
		{
			"base": "@dummy",
			"unit": "@dummy"
		}
	],
	"forbiddenLogs": [
		{
			"filter": {
				"source": "System",
				"type": "ExecutionException",
				"payload": {
					"regex": "^ABORTED$"
				}
			}
		}
	],
	"expectedLogs": [
		{
			"filter": {
				"source": "Player",
				"type": "Custom",
				"payload": {
					"regex": "^first message"
				}
			}
		},
		{
			"filter": {
				"source": "Player",
				"type": "Custom",
				"payload": {
					"regex": "^second message"
				}
			}
		},
		{
			"filter": {
				"source": "Player",
				"type": "Custom",
				"payload": {
					"regex": "^third message"
				}
			}
		},
		{
			"filter": {
				"source": "Player",
				"type": "Custom",
				"payload": {
					"regex": "^\\[PASS\\] log \\+ log_str simple test"
				}
			}
		}
	]
}