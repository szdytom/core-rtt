# Required
CORERTT_WORKER_BACKEND_URL=http://127.0.0.1:3000
CORERTT_WORKER_ID=worker-1
CORERTT_WORKER_SECRET=secret-1

# Optional
# CORERTT_WORKER_REPO_ROOT=/home/you/code/core-rtt
# CORERTT_WORKER_HEADLESS_PATH=/home/you/code/core-rtt/build/corertt_headless
# CORERTT_WORKER_TIMEOUT_SECONDS=1800
# CORERTT_WORKER_MAX_TICKS=5000
# CORERTT_WORKER_ELF_CACHE_DIR=/dev/shm/corertt-elf-cache
# CORERTT_WORKER_ELF_CACHE_LIMIT=200M
# CORERTT_WORKER_TMP_MAP_DIR=/dev/shm/corertt-tmp-map
# CORERTT_WORKER_CONCURRENCY=2
# CORERTT_WORKER_ERROR_LOG_MAX_BYTES=65536

# Optional: explicit .env path (otherwise defaults to js/core-worker/.env)
# CORERTT_WORKER_ENV_PATH=/home/you/code/core-rtt/js/core-worker/.env
