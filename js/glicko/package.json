{
	"name": "@corertt/glicko",
	"version": "1.0.0",
	"description": "A Glicko rating system implementation in TypeScript.",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "vitest run"
	},
	"packageManager": "pnpm@10.8.1",
	"devDependencies": {
		"@types/node": "^25.5.0",
		"glicko2": "^1.2.1",
		"typescript": "^6.0.2",
		"vitest": "^4.1.1"
	}
}
