{
	"version": 1,
	"name": "rust async scheduler integration test",
	"runs": 1,
	"timeLimitMs": 2000,
	"maxTicks": 20,
	"program": [
		{
			"base": "@dummy",
			"unit": "rusty::async_tasks"
		},
		{
			"base": "@dummy",
			"unit": "@dummy"
		}
	],
	"forbiddenLogs": [
		{
			"filter": {
				"source": "System",
				"type": "ExecutionException",
				"payload": {
					"regex": "^ABORTED$"
				}
			}
		}
	],
	"expectedLogs": [
		{
			"filter": {
				"source": "Player",
				"type": "Custom",
				"payload": {
					"regex": "^async tasks completed$"
				}
			}
		}
	]
}