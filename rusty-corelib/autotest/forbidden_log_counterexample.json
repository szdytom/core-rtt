{
	"version": 1,
	"name": "rust forbiddenLogs interception counterexample",
	"runs": 1,
	"expectFailure": true,
	"timeLimitMs": 2000,
	"maxTicks": 10,
	"program": [
		{
			"base": "rusty::abort_immediately",
			"unit": "@dummy"
		},
		{
			"base": "@dummy",
			"unit": "@dummy"
		}
	],
	"forbiddenLogs": [
		{
			"filter": {
				"source": "System",
				"type": "ExecutionException",
				"payload": {
					"regex": "^ABORTED$"
				}
			}
		}
	],
	"expectedLogs": []
}